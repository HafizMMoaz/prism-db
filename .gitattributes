# Normalize line endings repo-wide so Linux/macOS/Windows devs don't churn.
# Text files are stored as LF in the repository regardless of local config.
* text=auto eol=lf

# Explicitly LF for source and config we control.
*.rs    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf

# Windows-only scripts keep CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary files: never touch.
*.node  binary
*.png   binary
*.jpg   binary
*.ico   binary
*.prism binary
